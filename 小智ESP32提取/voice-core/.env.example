# Copy this file to .env and fill in your own values.
# DeepSeek is OpenAI-compatible, so these defaults match the Xiaozhi DeepSeek adapter.
XIAOZHI_LLM_API_KEY=sk-your-key-here
XIAOZHI_LLM_BASE_URL=https://api.deepseek.com
XIAOZHI_LLM_MODEL=deepseek-chat

# Optional: choose the voice used by EdgeTTS.
XIAOZHI_TTS_VOICE=zh-CN-XiaoxiaoNeural

# Optional: force provider names from config.yaml.
XIAOZHI_LLM_PROVIDER=DeepSeekLLM
XIAOZHI_TTS_PROVIDER=EdgeTTS
XIAOZHI_ASR_PROVIDER=FunASR

# Optional: local ASR model path.
# On Windows, prefer an ASCII-only path to avoid FunASR path issues.
# Example: C:\Users\YOUR_NAME\.cache\xiaozhi-models\SenseVoiceSmall
XIAOZHI_ASR_MODEL_DIR=models/SenseVoiceSmall
